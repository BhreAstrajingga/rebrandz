#!/usr/bin/env bash
set -euo pipefail

# Validate pushed branch names against pattern:
# {number}-{feature-kebab}-vX.Y.Z[-alpha|-beta|-rc]-{breaking|major|minor|patch}

pattern='^[0-9]{3,}-[a-z0-9]+(?:-[a-z0-9]+)*-v[0-9]+\.[0-9]+\.[0-9]+(?:-(?:alpha|beta|rc))?-(breaking|major|minor|patch)$'

invalid=()
while read -r local_ref local_sha remote_ref remote_sha; do
  # Only validate branches (ignore tags or other refs)
  if [[ "$local_ref" == refs/heads/* ]]; then
    branch="${local_ref#refs/heads/}"
    if [[ ! "$branch" =~ $pattern ]]; then
      invalid+=("$branch")
    fi
  fi
done

if (( ${#invalid[@]} > 0 )); then
  printf "✗ Invalid branch name(s):\n"
  for b in "${invalid[@]}"; do
    printf "  - %s\n" "$b"
  done
  cat <<'MSG'

Expected: {number}-{feature-kebab}-vX.Y.Z(-alpha|-beta|-rc)?-{breaking|major|minor|patch}
Examples:
  0123-user-slugs-v1.2.0-major
  0456-remove-tenancy-v2.0.0-breaking
  0789-service-slugs-v1.2.1-patch

Tip: git checkout -b 0123-your-feature-v1.0.0-major
MSG
  exit 1
fi

exit 0
